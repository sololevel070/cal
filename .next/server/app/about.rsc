full of mortgage calculators, but we found that most of them suffer from the same problems:"}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Hidden Costs:"}]," Many calculators only show principal and interest, hiding the true cost of taxes, insurance, and HOA fees until it's too late."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Clunky Interfaces:"}]," Most tools are outdated, not mobile-friendly, and difficult to use on the go."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lead Generation Traps:"}]," Too many sites force you to enter your email or phone number just to see your results, leading to endless spam calls from lenders."]}]]}],["$","p",null,{"children":"We built ClearNest to be the antidote to these problems. Our tools are 100% free, require no personal information, and include all the hidden costs of homeownership upfront."}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Our Commitment to Accuracy (E-E-A-T)"}],["$","p",null,{"children":"We understand that the numbers we provide influence major life decisions. That's why we adhere to the highest standards of Experience, Expertise, Authoritativeness, and Trustworthiness (E-E-A-T):"}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Expertise:"}]," Our calculation engines are built using standard industry formulas used by actual lenders and financial institutions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Transparency:"}]," We clearly explain how every number is calculated. You can see the exact formulas we use on our calculator pages."]}],["$","li",null,{"children":[["$","strong",null,{"children":"No Bias:"}]," We are an independent platform. We are not a lender, and we do not steer you toward specific loan products. Our only goal is to provide you with accurate math."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Privacy First:"}]," We do not collect, store, or sell your personal financial data. All calculations happen directly in your browser."]}]]}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Contact Us"}],["$","p",null,{"children":"Have a question, suggestion, or found a bug? We'd love to hear from you."}],["$","p",null,{"children":["Email us at: ",["$","a",null,{"href":"mailto:hello@clearnest.app","className":"text-primary hover:underline","children":"hello@clearnest.app"}]]}]]}]]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","about","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/47ecf0f34bd5f332.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","suppressHydrationWarning":true,"className":"__variable_f367f3","children":["$","body",null,{"suppressHydrationWarning":true,"className":"__className_f367f3 bg-slate-50 text-slate-900 overflow-x-hidden min-h-screen flex flex-col","children":[["$","$L4",null,{}],["$","main",null,{"className":"flex-1 pb-24 lg:pb-0","children":["$","$L5",null,{"children":["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":["$","div",null,{"className":"min-h-screen flex flex-col items-center justify-center bg-slate-50","children":[["$","h1",null,{"className":"text-4xl font-bold text-slate-800 mb-4","children":"404"}],["$","p",null,{"className":"text-slate-500 mb-8","children":"Page not found"}],["$","a",null,{"href":