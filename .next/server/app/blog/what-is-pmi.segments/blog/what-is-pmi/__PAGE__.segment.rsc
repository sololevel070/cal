0:{"buildId":"F2MJvTsbO_WeI8wcV_nqY","rsc":["$","$1","c",{"children":[["$","article",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"What is PMI (Private Mortgage Insurance)?\",\"datePublished\":\"2026-03-05\",\"dateModified\":\"2026-03-05\",\"author\":{\"@type\":\"Organization\",\"name\":\"ClearNest\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"ClearNest\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://clearnest.app\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://clearnest.app/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"What is PMI\",\"item\":\"https://clearnest.app/blog/what-is-pmi\"}]}"}}],["$","div",null,{"className":"mb-8 border-b border-border pb-8","children":[["$","h1",null,{"className":"text-4xl md:text-5xl font-bold text-text-primary mb-4 leading-tight","children":"What is PMI (Private Mortgage Insurance)?"}],["$","div",null,{"className":"text-text-muted flex items-center gap-4 text-sm","children":[["$","span",null,{"children":"By ClearNest Editorial Team"}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"Last Updated: March 5, 2026"}]]}]]}],["$","div",null,{"className":"prose prose-lg max-w-none text-text-primary","children":[["$","p",null,{"children":"If you're buying a home with a conventional loan and putting down less than 20%, you'll likely have to pay for Private Mortgage Insurance (PMI). But what exactly is it, and how does it affect your monthly payments?"}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"What Does PMI Do?"}],["$","p",null,{"children":["PMI is an insurance policy that protects the ",["$","em",null,{"children":"lender"}],"—not you—in case you default on your mortgage. Because a smaller down payment represents a higher risk for the lender, PMI is required to offset that risk."]}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"How Much Does PMI Cost?"}],["$","p",null,{"children":"The cost of PMI varies depending on several factors, including:"}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Your credit score:"}]," A higher credit score usually means lower PMI premiums."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Your down payment amount:"}]," The closer you are to 20%, the lower your PMI will be."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The loan type:"}]," Fixed-rate vs. adjustable-rate mortgages can have different PMI costs."]}]]}],["$","p",null,{"children":"On average, expect to pay between 0.5% and 1.5% of the original loan amount per year in PMI. For a $300,000 loan, this translates to roughly $125 to $375 per month added to your mortgage payment."}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"How to Avoid or Remove PMI"}],["$","h3",null,{"className":"text-2xl font-semibold mt-8 mb-3","children":"1. Put Down 20%"}],["$","p",null,{"children":"The most straightforward way to avoid PMI entirely is to make a down payment of at least 20% of the home's purchase price."}],["$","h3",null,{"className":"text-2xl font-semibold mt-8 mb-3","children":"2. Reach 20% Equity"}],["$","p",null,{"children":"Once you've paid down your mortgage balance to 80% of the home's original value, you can request that your lender cancel your PMI. By law, lenders must automatically terminate PMI when your balance reaches 78% of the original value."}],"$L2","$L3","$L4"]}]]}],null,"$L5"]}],"loading":null,"isPartial":false}
2:["$","h3",null,{"className":"text-2xl font-semibold mt-8 mb-3","children":"3. Refinance"}]
3:["$","p",null,{"children":"If your home has increased in value significantly since you bought it, you might have reached 20% equity sooner than expected. Refinancing your mortgage based on the new, higher appraised value can eliminate PMI."}]
4:["$","div",null,{"className":"bg-slate-50 p-8 rounded-2xl border border-border my-10 text-center","children":[["$","h3",null,{"className":"text-2xl font-bold mb-4","children":"Calculate Your PMI"}],["$","p",null,{"className":"mb-6 text-text-muted","children":"Use our mortgage calculator to see exactly how much PMI will add to your monthly payment."}],["$","$L6",null,{"href":"/mortgage-calculator","className":"inline-block bg-primary text-white px-8 py-3 rounded-full font-medium hover:bg-blue-700 transition-colors","children":"Calculate Mortgage with PMI"}]]}]
