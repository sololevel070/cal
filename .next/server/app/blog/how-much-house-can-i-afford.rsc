0:["w17sF4o8UECvYyDPoAln_",[[["",{"children":["blog",{"children":["how-much-house-can-i-afford",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":["how-much-house-can-i-afford",{"children":["__PAGE__",{},[["$L1",["$","article",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How Much House Can I Afford?\",\"datePublished\":\"2026-03-15\",\"dateModified\":\"2026-03-15\",\"author\":{\"@type\":\"Organization\",\"name\":\"ClearNest\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"ClearNest\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://clearnest.app\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://clearnest.app/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"How Much House Can I Afford?\",\"item\":\"https://clearnest.app/blog/how-much-house-can-i-afford\"}]}"}}],["$","div",null,{"className":"mb-8 border-b border-border pb-8","children":[["$","h1",null,{"className":"text-4xl md:text-5xl font-bold text-text-primary mb-4 leading-tight","children":"How Much House Can I Afford?"}],["$","div",null,{"className":"text-text-muted flex items-center gap-4 text-sm","children":[["$","span",null,{"children":"By ClearNest Editorial Team"}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"Last Updated: March 15, 2026"}]]}]]}],["$","div",null,{"className":"prose prose-lg max-w-none text-text-primary","children":[["$","div",null,{"className":"bg-blue-50 border-l-4 border-primary p-6 rounded-r-xl mb-8","children":[["$","h2",null,{"className":"text-xl font-bold text-primary mt-0 mb-2","children":"Quick Answer"}],["$","p",null,{"className":"m-0 text-text-primary","children":["To determine how much house you can afford, lenders typically use the ",["$","strong",null,{"children":"28/43 rule"}],". This means your monthly housing costs (mortgage, taxes, insurance) should not exceed 28% of your gross monthly income, and your total monthly debt payments (including the mortgage) should not exceed 43% of your gross income."]}]]}],["$","p",null,{"children":"Buying a home is one of the largest financial decisions you'll ever make. Before you start browsing listings or attending open houses, it's crucial to understand exactly how much house you can comfortably afford. This prevents you from becoming \"house poor\"—having a beautiful home but struggling to pay for other necessities."}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"The 28/43 Rule Explained"}],["$","p",null,{"children":"Most mortgage lenders use the 28/43 rule as a baseline to determine your borrowing capacity. This rule consists of two parts: the front-end ratio and the back-end ratio."}],["$","h3",null,{"className":"text-2xl font-semibold mt-8 mb-3","children":"The Front-End Ratio (28%)"}],["$","p",null,{"children":"Your front-end ratio, also known as your housing ratio, dictates that your total monthly housing costs should not exceed 28% of your gross monthly income (your income before taxes)."}],["$","p",null,{"children":["$","strong",null,{"children":"Housing costs include PITI:"}]}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"P"}],"rincipal (the loan amount)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"I"}],"nterest (the cost of borrowing)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"T"}],"axes (property taxes)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"I"}],"nsurance (homeowners insurance and PMI, if applicable)"]}],["$","li",null,{"children":"HOA fees (if applicable)"}]]}],["$","h3",null,{"className":"text-2xl font-semibold mt-8 mb-3","children":"The Back-End Ratio (43%)"}],["$","p",null,{"children":"Your back-end ratio, or Debt-to-Income (DTI) ratio, dictates that your total monthly debt payments should not exceed 43% of your gross monthly income."}],["$","p",null,{"children":["$","strong",null,{"children":"Total debts include:"}]}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":"Your new mortgage payment (PITI)"}],["$","li",null,{"children":"Auto loans"}],["$","li",null,{"children":"Student loans"}],["$","li",null,{"children":"Minimum credit card payments"}],["$","li",null,{"children":"Child support or alimony"}]]}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Example Calculation"}],["$","p",null,{"children":"Let's say your household earns $120,000 per year, which is $10,000 per month gross income. You currently pay $500/month for a car loan and $300/month for student loans."}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Front-end limit (28%):"}]," $10,000 × 0.28 = $2,800 maximum monthly housing payment."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Back-end limit (43%):"}]," $10,000 × 0.43 = $4,300 maximum total debt. Subtracting your $800 in existing debts leaves $3,500 for housing."]}]]}],["$","p",null,{"children":["Since lenders use the lower of the two numbers, your maximum monthly housing payment would be ",["$","strong",null,{"children":"$$2,800"}],"."]}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Other Factors Lenders Consider"}],["$","p",null,{"children":"While the 28/43 rule is a great starting point, lenders also look at:"}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Credit Score:"}]," A higher score can qualify you for a lower interest rate, which increases your purchasing power. ",["$","$L2",null,{"href":"/blog/what-credit-score-to-buy-house","className":"text-primary hover:underline","children":"Learn more about credit scores."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Down Payment:"}]," A larger down payment reduces your loan amount and can eliminate the need for Private Mortgage Insurance (PMI). ",["$","$L2",null,{"href":"/blog/what-is-pmi","className":"text-primary hover:underline","children":"Learn more about PMI."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Employment History:"}]," Lenders typically want to see at least two years of stable employment in the same industry."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cash Reserves:"}]," Having savings left over after closing shows lenders you can handle unexpected expenses."]}]]}],["$","div",null,{"className":"bg-slate-50 p-8 rounded-2xl border border-border my-10 text-center","children":[["$","h3",null,{"className":"text-2xl font-bold mb-4","children":"Ready to see your numbers?"}],["$","p",null,{"className":"mb-6 text-text-muted","children":"Use our free affordability calculator to get a personalized estimate based on your exact income and debts."}],["$","$L2",null,{"href":"/affordability-calculator","className":"inline-block bg-primary text-white px-8 py-3 rounded-full font-medium hover:bg-blue-700 transition-colors","children":"Calculate My Affordability"}]]}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Frequently Asked Questions"}],["$","div",null,{"className":"space-y-6 mt-6","children":[["$","div",null,{"children":[["$","h3",null,{"className":"text-xl font-semibold mb-2","children":"Can I get a mortgage with a DTI higher than 43%?"}],["$","p",null,{"className":"text-text-muted","children":"Yes, some loan programs, like FHA loans or certain conventional loans with strong compensating factors (like a high credit score or large cash reserves), may allow a DTI up to 50%."}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-xl font-semibold mb-2","children":"Does the 28/43 rule apply to net income or gross income?"}],["$","p",null,{"className":"text-text-muted","children":"The rule applies to your gross income, which is your income before taxes and deductions are taken out."}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-xl font-semibold mb-2","children":"Should I borrow the maximum amount I qualify for?"}],["$","p",null,{"className":"text-text-muted","children":"Not necessarily. Just because a lender approves you for a certain amount doesn't mean it fits your personal budget. Consider your lifestyle, future goals, and other expenses like childcare or travel."}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-xl font-semibold mb-2","children":"How does the interest rate affect affordability?"}],["$","p",null,{"className":"text-text-muted","children":"A higher interest rate increases your monthly payment for the same loan amount, which decreases the total home price you can afford. Even a 1% difference can significantly impact your purchasing power."}]]}],["$","div",null,{"children":[["$","h3",null,{"className":"text-xl font-semibold mb-2","children":"Do I need a 20% down payment?"}],["$","p",null,{"className":"text-text-muted","children":"No. While 20% helps you avoid PMI, many programs allow down payments as low as 3% (conventional) or 3.5% (FHA). VA and USDA loans even offer 0% down options for qualified buyers."}]]}]]}],["$","div",null,{"className":"mt-12 pt-8 border-t border-border text-sm text-text-muted italic","children":"Disclaimer: Results are estimates. ClearNest provides educational content and is not a licensed lender or financial advisor. Consult a licensed mortgage professional for personalized advice."}]]}]]}],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["