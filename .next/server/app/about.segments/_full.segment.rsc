b:["$","$1","c",{"children":[["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"AboutPage\",\"name\":\"About ClearNest\",\"description\":\"Learn about ClearNest's mission to provide transparent, accurate, and easy-to-use mortgage tools for homebuyers.\",\"url\":\"https://clearnest.app/about\"}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://clearnest.app\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"About Us\",\"item\":\"https://clearnest.app/about\"}]}"}}],["$","div",null,{"className":"mb-12 text-center","children":[["$","h1",null,{"className":"text-4xl font-bold text-text-primary mb-4","children":"About ClearNest"}],["$","p",null,{"className":"text-xl text-text-muted max-w-2xl mx-auto","children":"Demystifying the mortgage process with clear, accurate, and user-friendly tools."}]]}],["$","div",null,{"className":"prose prose-lg max-w-none text-text-primary","children":[["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Our Mission"}],["$","p",null,{"children":"At ClearNest, we believe that buying a home shouldn't require a degree in finance. Our mission is to empower homebuyers with the most accurate, transparent, and easy-to-use mortgage calculators on the web. We want to help you make confident financial decisions by providing clear insights into your true housing costs."}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Why We Built ClearNest"}],["$","p",null,{"children":"The internet is full of mortgage calculators, but we found that most of them suffer from the same problems:"}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Hidden Costs:"}]," Many calculators only show principal and interest, hiding the true cost of taxes, insurance, and HOA fees until it's too late."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Clunky Interfaces:"}]," Most tools are outdated, not mobile-friendly, and difficult to use on the go."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lead Generation Traps:"}]," Too many sites force you to enter your email or phone number just to see your results, leading to endless spam calls from lenders."]}]]}],["$","p",null,{"children":"We built ClearNest to be the antidote to these problems. Our tools are 100% free, require no personal information, and include all the hidden costs of homeownership upfront."}],["$","h2",null,{"className":"text-3xl font-semibold mt-10 mb-4","children":"Our Commitment to Accuracy (E-E-A-T)"}],["$","p",null,{"children":"We understand that the numbers we provide influence major life decisions. That's why we adhere to the highest standards of Experience, Expertise, Authoritativeness, and Trustworthiness (E-E-A-T):"}],["$","ul",null,{"className":"list-disc pl-6 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Expertise:"}]," Our calculation engines are built using standard industry formulas used by actual lenders and financial institutions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Transparency:"}]," We clearly explain how every number is calculated. You can see the exact formulas we use on our calculator pages."]}],["$","li",null,{"children":[["$","strong",null,{"children":"No Bias:"}]," We are an independent platform. We are not a lender, and we do not steer you toward specific loan products. Our only goal is to provide you with accurate math."]}],"$Le"]}],"$Lf","$L10","$L11"]}]]}],null,"$L12"]}]
